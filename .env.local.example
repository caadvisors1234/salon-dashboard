# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role (server-only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/business.manage openid email

# Token Encryption (AES-256-GCM) - generate with: openssl rand -hex 32
GOOGLE_TOKEN_ENCRYPTION_KEY=your-32-byte-hex-key

# Batch Worker
BATCH_DAILY_CRON=0 18 * * *
BATCH_MONTHLY_CRON=0 18 8 * *
BATCH_BACKFILL_DAYS=30
BATCH_HEALTH_PORT=3001

# PDF Report Token (JWT) - generate with: openssl rand -base64 32
REPORT_TOKEN_SECRET=your-report-token-secret

# E2E Testing (Playwright)
E2E_USER_EMAIL=your-test-user@example.com
E2E_USER_PASSWORD=your-test-password

# Email Notification (Resend) - https://resend.com
RESEND_API_KEY=
BATCH_NOTIFICATION_FROM=onboarding@resend.dev
